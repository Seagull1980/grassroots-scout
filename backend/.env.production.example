# PRODUCTION ENVIRONMENT VARIABLES FOR RENDER.COM
# Copy this file to .env.production and update values for your Render deployment

# Database Configuration
DB_TYPE=sqlite

# Backend Environment Variables
PORT=3000
JWT_SECRET=CHANGE-THIS-TO-A-STRONG-SECRET-KEY-IN-PRODUCTION
NODE_ENV=production

# Encryption Configuration (MUST be exactly 64 hex characters = 32 bytes)
ENCRYPTION_KEY=GENERATE-A-NEW-64-CHARACTER-HEX-KEY-FOR-PRODUCTION

# Frontend URL - CRITICAL FOR EMAIL VERIFICATION AND CORS
# Set this to your actual production frontend URL
# Example: https://www.yourdomain.com
FRONTEND_URL=https://www.yourdomain.com

# Additional browser origins allowed to call the API
# Include every production frontend hostname that should be able to access the API
# Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Configuration
EMAIL_USER=replace-with-smtp-user@example.com
EMAIL_PASS=your-gmail-app-password-here
EMAIL_PASSWORD=your-gmail-app-password-here
EMAIL_FROM="Grassroots Hub <noreply@grassrootshub.com>"

# IMPORTANT NOTES:
# 1. FRONTEND_URL must match your actual production frontend URL
# 2. Without this, email verification links will point to localhost and won't work
# 3. CORS_ALLOWED_ORIGINS should include every frontend hostname served through Cloudflare/Vercel
# 4. Update these values in your hosting dashboard: Environment > Environment Variables
# 5. After updating FRONTEND_URL and CORS_ALLOWED_ORIGINS, redeploy your application
